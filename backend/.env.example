PORT=8000
NODE_ENV=development
BASE_PATH=/api

MONGO_URI="mongodb+srv://<username>:<password>@<>.mongodb.net/teamsync_db"

SESSION_SECRET="session_secret_key"
SESSION_EXPIRES_IN="1d"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# For local dev
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost:3000/google/callback

# For Cloud Run production (replace with actual URLs)
# FRONTEND_ORIGIN=https://teamsync-frontend-xxxxx.asia-southeast1.run.app
# GOOGLE_CALLBACK_URL=https://teamsync-backend-xxxxx.asia-southeast1.run.app/api/auth/google/callback
# FRONTEND_GOOGLE_CALLBACK_URL=https://teamsync-frontend-xxxxx.asia-southeast1.run.app/google/callback